---
import "../styles/global.css";
import CookieConsentBanner from "../components/CookieConsentBanner.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;


import LOGO from "../assets/logo.jpg";
import OG_IMAGE from "../assets/taxiPeraltaBanner.jpg";
const URL = "https://taxiperalta.com";
---

<!doctype html>
<html lang="es" class="dark scroll-smooth">
  <head>
    <!-- Google tag (gtag.js) -->
    <!--<script async src="https://www.googletagmanager.com/gtag/js?id=G-RR6JVP116W"></script>-->
    <!--<script>-->
    <!--  // @ts-nocheck-->
    <!--  window.dataLayer = window.dataLayer || [];-->
    <!--  function gtag(){dataLayer.push(arguments)}-->
    <!--  gtag('js', new Date());-->

    <!--  gtag('config', 'G-RR6JVP116W');-->
    <!--</script>-->
    <meta charset="UTF-8" />
    <meta name="description" content="Taxi de Peralta, Navarra (España)" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={LOGO.src} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="author" content="Burdas">
    <!-- Meta etiquetas para redes sociales (Open Graph) -->
    <meta property="og:site_name" content="Taxi Peralta">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Taxi Peralta">
    <meta property="og:description" content="Taxi de Peralta, Navarra (España)">
    <meta property="og:image:secure_url" itemprop="image" content={URL + OG_IMAGE.src}>
    <meta property="og:image:secure_url" content={URL + OG_IMAGE.src}>
    <meta property="og:image" content={URL + OG_IMAGE.src}>
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:url" content={URL}>
    <meta property="og:updated_time" content="1717150800" />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image:alt" content="Imagen de portada con el coche y el nombre" />
    

    <!-- Meta etiquetas para Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Taxi Peralta">
    <meta name="twitter:description" content="Taxi de Peralta, Navarra (España)">
    <meta name="twitter:image" content={URL + OG_IMAGE.src}>
    <meta name="twitter:url" content={URL}>
    <script type="text/javascript" is:inline>
      // Laod theme preferences
      if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body
    class="dark:bg-black transition-colors duration-300 ease-out"
  >
    <slot />
    <CookieConsentBanner />
  </body>
</html>
<style>
  body {
    font-family:
      ui-sans-serif,
      system-ui,
      sans-serif,
      "Apple Color Emoji",
      "Segoe UI Emoji",
      Segoe UI Symbol,
      "Noto Color Emoji";

    --sb-track-color: #FFF;
    --sb-thumb-color: #262626;
    --sb-size: 14px;
  }

  .dark body {
    font-family:
      ui-sans-serif,
      system-ui,
      sans-serif,
      "Apple Color Emoji",
      "Segoe UI Emoji",
      Segoe UI Symbol,
      "Noto Color Emoji";

    --sb-track-color: #000;
    --sb-thumb-color: #262626;
    --sb-size: 14px;
  }

  body::-webkit-scrollbar {
    width: var(--sb-size);
  }

  body::-webkit-scrollbar-track {
    background: var(--sb-track-color);
    border-radius: 1px;
  }

  body::-webkit-scrollbar-thumb {
    background: var(--sb-thumb-color);
    border-radius: 5px;
    border: 1px solid var(--sb-track-color);
  }
</style>
<script>
  import { routeList } from "../model/navbar.ts";

  const sectionElements = routeList
      .filter(item => item.href.includes("#"))
      .map(item => document.getElementById(item.href.replace("./#", "")))
      .filter(el => el !== null);
  const heroSection = document.getElementById('heroSection');
  heroSection && sectionElements.push(heroSection);
  const fiestasDePeraltaSection = document.getElementById('FiestasDePeralta');
  fiestasDePeraltaSection && sectionElements.push(fiestasDePeraltaSection);
  const politicaDePrivacidadSection = document.getElementById('PoliticaDePrivacidad');
  politicaDePrivacidadSection && sectionElements.push(politicaDePrivacidadSection);

  const mapSections = (section: string):string => {
    switch (section) {
      case "heroSection":
        return "Portada";
      case "FiestasDePeralta":
        return "Fiestas de Peralta";
      case "PoliticaDePrivacidad":
        return "Política de privacidad";
      case "Informacion":
        return "Información";
      case "Galeria":
          return "Galería";
      case "Enlaces":
          return "Enlaces de interés";
      default:
        return section;
    }
  }

  const buildObserver = () => new IntersectionObserver(
      (entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const pagina = mapSections(entry.target.id);
            
            // Always track, but anonymize IP without consent
            const cookies = document.cookie.split(';');
            const consentCookie = cookies.find(c => c.trim().startsWith('analytics_consent='));
            const hasConsent = consentCookie?.split('=')[1] === 'true';

            const visita = {
              ip: hasConsent ? 'pending' : 'IP no disponible',
              pagina: pagina,
            };

            if (hasConsent) {
              fetch('/api/ip')
                .then(res => res.json())
                .then(({ ip }) => {
                  visita.ip = ip;
                  fetch('/api/visitas', {
                    method: "POST",
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(visita),
                  });
                });
            } else {
              fetch('/api/visitas', {
                method: "POST",
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(visita),
              });
            }

            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.3
      }
  );

  sectionElements.map(section => {
    const observer = buildObserver();
    observer.observe(section)
  });
</script>
